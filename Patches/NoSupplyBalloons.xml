<?xml version="1.0" encoding="utf-8"?>
<!--
    Stop the "Supply Balloons" event from ever being rolled.

    "Supply Balloons" is Medieval Fantasy Themed Relic Quests' reskin (letter + text) of the vanilla
    ResourcePodCrash incident - a cluster of cargo pods crash near the colony with free loot.
    ResourcePodCrash is a Misc-category incident; zeroing its baseChance (its weight in the Misc pool)
    is not a reliable disable for these events. Instead empty its targetTags: an incident whose
    targetTags is empty fails IncidentWorker.CanFireNow for any target, so no storyteller comp can ever
    select it - the same bulletproof disable used for the ground trade caravans and RefugeePodCrash.

    Edits the Core incident directly, so it's global - no storyteller rolls it. Reward/gift drop-pod
    deliveries are a separate mechanism and are unaffected.
-->
<Patch>
    <Operation Class="PatchOperationReplace">
        <xpath>Defs/IncidentDef[defName="ResourcePodCrash"]/targetTags</xpath>
        <value>
            <targetTags />
        </value>
    </Operation>
</Patch>
